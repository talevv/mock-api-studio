<section class="p-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Endpoints</h1>
    <p class="mt-1 text-sm text-slate-600">A table view of API endpoints with method, name, and path.</p>
  </div>

  {{#if updateSuccess}}
    <div class="mt-4 p-4 bg-green-100 text-green-800">
      Endpoints updated successfully!
    </div>
  {{/if}}

  {{#if endpoints.length}}
    <table class="table-auto w-full mt-4 border-collapse text-left border border-slate-200">
      <thead>
        <tr class="bg-gray-100">
          <th class="p-2 border-b border-slate-200">Method</th>
          <th class="p-2 border-b border-slate-200">Name</th>
          <th class="p-2 border-b border-slate-200">Path</th>
          <th class="p-2 border-b border-slate-200">Active</th>
          <th class="p-2 border-b border-slate-200">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each endpoints}}
          <tr class="{{bgClass}}">
            <td class="p-2 border-b border-slate-200">
              <span class="{{methodColor}} px-2 py-1 rounded-md text-xs font-medium">
                {{method}}
              </span>
            </td>
            <td class="p-2 border-b border-slate-200">
              <a href="/endpoints/{{id}}" class="text-blue-600 hover:underline">
                {{name}}
              </a>
            </td>
            <td class="p-2 border-b border-slate-200 font-mono text-sm">{{path}}</td>
            <td class="p-2 border-b border-slate-200">
              <input 
                type="checkbox" 
                name="active" 
                value="{{id}}" 
                {{#if active}}checked{{/if}}
                hx-post="/endpoints/{{id}}/toggle"
              >
            </td>
            <td class="p-2 border-b border-slate-200">
              <form method="post" action="/endpoints/{{id}}/move" class="inline-flex">
                <button name="direction" value="up">↑</button>
                <button name="direction" value="down">↓</button>
              </form>
              <a href="/endpoints/{{id}}/edit" class="text-blue-600 hover:underline mr-4">
                Edit
              </a>
              <button type="submit" class="px-2 py-1 bg-red-600 text-white text-xs font-medium rounded-md hover:bg-red-700" formmethod="post" formaction="/endpoints/{{id}}/delete">
                Delete
              </button>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <div class="mt-6 text-slate-600">
      No endpoints defined yet. Start by creating a new endpoint.
    </div>
  {{/if}}
</section>
