{{#if serverRunning}}
  <button 
    type="button" 
    class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded"
    hx-post="/server/stop"
    hx-swap="outerHTML"
  >
    Stop server
  </button>
{{else}}
  <button 
    type="button" 
    class="bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded"
    hx-post="/server/run"
    hx-swap="outerHTML"
  >
    Run server
  </button>
{{/if}}